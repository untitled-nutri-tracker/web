% Gemini theme
% https://github.com/anishathalye/gemini

% ====================
% Definitions
% ====================

% Colors from https://brand.vt.edu/identity/color.html
\definecolor{chicago_maroon}{RGB}{134, 31, 65}
\definecolor{burnt_orange}{RGB}{232, 119, 34}
\definecolor{hokie_stone}{RGB}{117, 120, 123}

% Extra colors
\definecolor{lightgray}{RGB}{240, 240, 240}
\definecolor{lightorange}{RGB}{255, 245, 242}

% ====================
% Theme
% ====================

% Basic colors
\setbeamercolor{palette primary}{fg=black,bg=white}
\setbeamercolor{palette secondary}{fg=black,bg=white}
\setbeamercolor{palette tertiary}{bg=black,fg=white}
\setbeamercolor{palette quaternary}{fg=black,bg=white}
\setbeamercolor{structure}{fg=chicago_maroon}


% Headline
\setbeamercolor{headline}{fg=white,bg=chicago_maroon}

% Block
\setbeamercolor{block title}{fg=chicago_maroon,bg=white}
\setbeamercolor{block separator}{bg=burnt_orange}
\setbeamercolor{block body}{fg=black,bg=white}

% Alert Block
\setbeamercolor{block alerted title}{fg=chicago_maroon,bg=lightorange}
\setbeamercolor{block alerted separator}{bg=black}
\setbeamercolor{block alerted body}{fg=black,bg=lightorange}

% Example Block
\setbeamercolor{block example title}{fg=chicago_maroon,bg=lightgray}
\setbeamercolor{block example separator}{bg=black}
\setbeamercolor{block example body}{fg=black,bg=lightgray}

% Heading
\setbeamercolor{heading}{fg=burnt_orange}

% Itemize
\setbeamercolor{item}{fg=chicago_maroon}

% Bibliography
\setbeamercolor{bibliography item}{fg=black}
\setbeamercolor{bibliography entry author}{fg=black}
\setbeamercolor{bibliography entry title}{fg=black}
\setbeamercolor{bibliography entry location}{fg=black}
\setbeamercolor{bibliography entry note}{fg=black}
